# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tmp utility folder — all local-only, never commit
tmp/

# Claude Code session data
.claude/

# Playwright MCP browser state
.playwright-mcp/

# Agent workflow data (contains plaintext credentials)
.agent/

# Database backups (sensitive — never commit)
DB Backups/

# Screenshot / deployment artifact PNGs in project root
coolify-*.png
create-page.png
media-*.png
media-picker*.png
product-*.png
terminal-test.png

# Local Directus uploaded files (production media synced locally — not for git)
directus-uploads/

# Local-only temp and settings files
.temp/
localsettings.md
